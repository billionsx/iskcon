{
  "name": "@iskcon/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "db:migrate:staging": "wrangler d1 migrations apply iskcon-db-staging --env staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply iskcon-db --env production --remote",
    "lint": "echo \"(eslint TBD)\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "hono": "^4.6.16",
    "@hono/zod-validator": "^0.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "wrangler": "^3.99.0",
    "typescript": "^5.7.3",
    "@types/bun": "^1.2.0"
  }
}
