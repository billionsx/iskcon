{
  "name": "iskcon",
  "version": "0.1.0",
  "private": true,
  "description": "Глобальная платформа ИСККОН (мульти-тенант / франшиза). Cloudflare Workers + D1 + KV + R2.",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@iskcon/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "@types/bun": "^1.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "packageManager": "bun@1.2.0",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
